# Servidor
PORT=3000
NODE_ENV=production

# PostgreSQL Railway
# Recomendado: copie a variavel DATABASE_URL do PostgreSQL no Railway
DATABASE_URL=postgresql://usuario:senha@host:porta/banco
PGSSL=true

# Segredo para rotas administrativas. Troque por uma frase grande.
ADMIN_SECRET=troque-essa-senha-admin

# Z-API WhatsApp
ZAPI_INSTANCE=
ZAPI_TOKEN=
ZAPI_CLIENT_TOKEN=

# Mercado Pago
MP_ACCESS_TOKEN=
MP_PUBLIC_KEY=

# DeepSeek / IA futura
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat
